{
  "name": "cayena",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run db:generate --workspace=@cayena/database",
    "db:migrate": "npm run db:migrate --workspace=@cayena/database",
    "db:seed": "npm run db:seed --workspace=@cayena/database",
    "db:studio": "npm run db:studio --workspace=@cayena/database"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
