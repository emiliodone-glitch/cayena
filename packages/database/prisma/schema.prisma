generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPERADMIN
  JEFE_SECRETARIA
  PROMOTOR
  AUDITOR
  DIRIGENCIA
  MILITANTE
}

enum CategoriaObra {
  EDUCACION
  SALUD
  VIALIDAD
  VIVIENDA
  DEPORTE
  AGUA_SANEAMIENTO
  ELECTRICIDAD
  SEGURIDAD
  OTRA
}

enum TipoMovimiento {
  INGRESO
  GASTO
}

// ---------------------------------------------------------------------------
// Geografía real (RF-13): provincias y municipios cargados desde GeoJSON
// (geoBoundaries DOM ADM1/ADM2, límites territoriales reales) via seed.
// ---------------------------------------------------------------------------

model Provincia {
  id     String @id // slug, coincide con properties.id del GeoJSON
  codigo String @unique // ISO 3166-2:DO, ej. DO-25
  nombre String
  // Electores hábiles según el padrón de la JCE (para calcular penetración
  // electoral en el mapa). Nulo hasta que se importe con import-electores.ts.
  electores Int?

  municipios Municipio[]
  militantes Militante[]
  obras      Obra[]
  metas      MetaMilitantes[]
  responsables User[] @relation("ResponsableProvincia")

  createdAt DateTime @default(now())
}

model Municipio {
  id          String    @id // slug compuesto `${provinciaId}__${municipioSlug}`
  nombre      String
  provinciaId String
  provincia   Provincia @relation(fields: [provinciaId], references: [id])
  electores   Int?

  militantes           Militante[]
  obras                Obra[]
  metas                MetaMilitantes[]
  distritosMunicipales DistritoMunicipal[]
  localidades          Localidad[]
  responsables         User[] @relation("ResponsableMunicipio")

  createdAt DateTime @default(now())

  @@index([provinciaId])
}

// Subdivisión de un municipio (RF-13.4). No existe geometría real disponible
// para este nivel en las fuentes GeoJSON usadas (geoBoundaries no publica
// ADM3 para RD), así que se gestiona como lista/tabla editable desde el back
// office en vez de una capa más en el mapa.
model DistritoMunicipal {
  id          String    @id @default(cuid())
  nombre      String
  municipioId String
  municipio   Municipio @relation(fields: [municipioId], references: [id])
  electores   Int?

  militantes Militante[]
  metas      MetaMilitantes[]
  responsables User[] @relation("ResponsableDistrito")

  createdAt DateTime @default(now())

  @@unique([municipioId, nombre])
  @@index([municipioId])
}

// Localidad dentro de un municipio (barrio/paraje/sección). Sin geometría
// real disponible (igual que el distrito municipal), se gestiona como lista
// editable desde el back office y sirve para filtrar el recinto electoral.
model Localidad {
  id          String    @id @default(cuid())
  nombre      String
  municipioId String
  municipio   Municipio @relation(fields: [municipioId], references: [id])

  militantes Militante[]
  recintos   RecintoElectoral[]

  createdAt DateTime @default(now())

  @@unique([municipioId, nombre])
  @@index([municipioId])
}

// Recinto electoral (local físico), vinculado a una localidad específica.
model RecintoElectoral {
  id          String    @id @default(cuid())
  nombre      String
  direccion   String?
  localidadId String
  localidad   Localidad @relation(fields: [localidadId], references: [id])

  militantes Militante[]
  colegios   Colegio[]

  createdAt DateTime @default(now())

  @@unique([localidadId, nombre])
  @@index([localidadId])
}

// Colegio electoral (la mesa exacta impresa en la cédula), dentro de un recinto.
model Colegio {
  id                 String           @id @default(cuid())
  numero             String
  recintoElectoralId String
  recintoElectoral   RecintoElectoral @relation(fields: [recintoElectoralId], references: [id])

  militantes Militante[]

  createdAt DateTime @default(now())

  @@unique([recintoElectoralId, numero])
  @@index([recintoElectoralId])
}

// ---------------------------------------------------------------------------
// Usuarios y secretarías
// ---------------------------------------------------------------------------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  nombre       String
  telefono     String?
  role         Role    @default(MILITANTE)
  active       Boolean @default(true)

  // Alcance del promotor/jefe de secretaría
  secretariaId String?
  secretaria   Secretaria? @relation(fields: [secretariaId], references: [id])
  // Rol dentro del equipo de la secretaría (ej. "Titular", "Vocal",
  // "Coordinador provincial") — solo tiene sentido con secretariaId puesto.
  // Quién es el TITULAR formal (el cargo, no cualquier miembro del equipo)
  // se define aparte en Secretaria.titularId; esto es solo la etiqueta
  // visible del rol de cada persona dentro del equipo.
  cargoSecretaria String?

  // Invitación de activación (self-service): en vez de que un SUPERADMIN le
  // teclee correo y contraseña a cada usuario creado por seed/carga masiva,
  // se genera un link de un solo uso — el destinatario entra, pone su
  // correo real y su propia contraseña, y el token se invalida. Nulo cuando
  // no hay invitación pendiente.
  invitacionToken  String?   @unique
  invitacionExpira DateTime?

  // Territorio asignado (coordinador de zona): a lo sumo uno de los tres
  // debiera estar presente a la vez (se valida en la app, no en la BD) — el
  // más específico define el alcance del usuario. Sin ninguno, el usuario
  // conserva la visibilidad nacional de siempre (compatibilidad con las
  // cuentas ya existentes). SUPERADMIN y AUDITOR siempre ven todo el país
  // sin importar si tienen algo asignado acá.
  provinciaId String?
  provincia   Provincia? @relation("ResponsableProvincia", fields: [provinciaId], references: [id])
  municipioId String?
  municipio   Municipio? @relation("ResponsableMunicipio", fields: [municipioId], references: [id])
  distritoMunicipalId String?
  distritoMunicipal   DistritoMunicipal? @relation("ResponsableDistrito", fields: [distritoMunicipalId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actividadesCreadas Actividad[]    @relation("ActividadCreador")
  obrasCreadas       Obra[]         @relation("ObraCreador")
  militantesCaptados Militante[]    @relation("MilitanteCapturador")
  gastosRegistrados  Gasto[]        @relation("GastoRegistrador")
  avancesRegistrados AvancePOA[]    @relation("AvanceRegistrador")
  refreshTokens      RefreshToken[]
  notificacionesRecibidas Notificacion[] @relation("NotificacionDestinatario")
  deviceTokens       DeviceToken[]
  secretariasComoTitular    Secretaria[]                 @relation("TitularActual")
  historialTitularidades    HistorialTitularSecretaria[] @relation("HistorialTitular")
  informesSubidos           InformeSecretaria[]          @relation("InformeAutor")
  checkInsRegistrados       AsistenciaActividad[]        @relation("CheckInRegistrador")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Secretaria {
  id          String  @id @default(cuid())
  nombre      String  @unique
  descripcion String?

  // Titular actual (cargo formal, uno solo a la vez). Distinto de
  // `usuarios` (el equipo completo: cualquier User con secretariaId
  // apuntando acá, titular incluido) — separar el cargo del simple
  // vínculo permite llevar historial de quién lo ha ocupado (ver
  // HistorialTitularSecretaria) sin depender de que el sistema adivine
  // "el titular" buscando un JEFE_SECRETARIA cualquiera del equipo.
  titularId String?
  titular   User?   @relation("TitularActual", fields: [titularId], references: [id])

  // Presupuesto asignado para el período vigente (RD$). El ejecutado se
  // calcula sumando Gasto (tipo GASTO) vinculado a esta secretaría — no se
  // duplica ese dato acá.
  presupuestoAsignado Decimal? @db.Decimal(14, 2)

  usuarios          User[]
  actividades       Actividad[]
  documentos        DocumentoSecretaria[]
  gastos            Gasto[]
  metasPoa          MetaPOA[]
  informes          InformeSecretaria[]
  historialTitulares HistorialTitularSecretaria[]

  createdAt DateTime @default(now())
}

model DocumentoSecretaria {
  id           String     @id @default(cuid())
  secretariaId String
  secretaria   Secretaria @relation(fields: [secretariaId], references: [id])
  titulo       String
  url          String
  subidoPorId  String?
  createdAt    DateTime   @default(now())

  @@index([secretariaId])
}

// Registro histórico de quién ha ocupado la titularidad de cada secretaría
// — al cambiar Secretaria.titularId se cierra la fila abierta (hasta =
// ahora) y se abre una nueva. nombreTitular queda como "foto" del nombre al
// momento de la designación: si el usuario cambia de nombre después, o la
// cuenta se reutiliza, el historial no se reescribe solo.
model HistorialTitularSecretaria {
  id           String     @id @default(cuid())
  secretariaId String
  secretaria   Secretaria @relation(fields: [secretariaId], references: [id])
  userId       String
  user         User       @relation("HistorialTitular", fields: [userId], references: [id])
  nombreTitular String
  desde        DateTime   @default(now())
  hasta        DateTime?

  createdAt DateTime @default(now())

  @@index([secretariaId])
}

// Rendición de cuentas periódica (RF nuevo): un informe de gestión por
// secretaría y período (p.ej. "2026-07"). Se usa tanto para exigirle a cada
// titular reportar avance con regularidad como para alertar cuando el
// período vigente se queda sin informe (ver lib/alertas.ts).
model InformeSecretaria {
  id           String     @id @default(cuid())
  secretariaId String
  secretaria   Secretaria @relation(fields: [secretariaId], references: [id])
  periodo      String // "YYYY-MM"
  resumen      String
  archivoUrl   String?
  subidoPorId  String?
  subidoPor    User?      @relation("InformeAutor", fields: [subidoPorId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([secretariaId, periodo])
  @@index([secretariaId])
}

// ---------------------------------------------------------------------------
// Actividades
// ---------------------------------------------------------------------------

model Actividad {
  id           String     @id @default(cuid())
  titulo       String
  descripcion  String?
  fecha        DateTime
  ubicacion    String?
  lat          Float?
  lng          Float?
  fotos        String[]
  secretariaId String
  secretaria   Secretaria @relation(fields: [secretariaId], references: [id])
  publicadaApp Boolean    @default(false)

  // Evita que el job de recordatorio (lib/recordatorios.ts) mande el push de
  // "faltan 24h" más de una vez para la misma actividad al correr en bucle.
  recordatorioEnviado Boolean @default(false)

  creadoPorId String
  creadoPor   User   @relation("ActividadCreador", fields: [creadoPorId], references: [id])

  asistencias AsistenciaActividad[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([secretariaId])
  @@index([fecha])
}

// Asistencia de militantes a una actividad — separa la CONFIRMACIÓN (RSVP
// desde la app, antes del evento) del CHECK-IN real (escaneado del carnet QR
// del militante por el organizador, el día del evento). Ambas cosas pueden
// darse independientes: alguien puede llegar sin haber confirmado antes, o
// confirmar y no asistir — checkInAt nulo distingue ese caso.
model AsistenciaActividad {
  id          String    @id @default(cuid())
  actividadId String
  actividad   Actividad @relation(fields: [actividadId], references: [id], onDelete: Cascade)
  militanteId String
  militante   Militante @relation(fields: [militanteId], references: [id], onDelete: Cascade)

  confirmado Boolean @default(true) // true = confirmó asistencia, false = canceló su RSVP

  checkInAt    DateTime?
  checkInPorId String?
  checkInPor   User?     @relation("CheckInRegistrador", fields: [checkInPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([actividadId, militanteId])
  @@index([actividadId])
  @@index([militanteId])
}

// ---------------------------------------------------------------------------
// Obras de gobierno
// ---------------------------------------------------------------------------

model Obra {
  id        String        @id @default(cuid())
  titulo    String
  resena    String
  categoria CategoriaObra
  // Fotos "después"/estado actual — el nombre se mantiene por compatibilidad
  // con datos ya cargados; fotosAntes es la galería nueva de comparación.
  fotos      String[]
  fotosAntes String[] @default([])
  lat        Float
  lng        Float
  // Referencia de dirección en texto libre (ej. "Calle Duarte esq. Mella"),
  // buscada con el mismo autocompletado de lugares que Actividades — separada
  // de provincia/municipio, que siguen siendo la demarcación oficial.
  direccion String?

  // Datos de una obra ya concluida (RF: catálogo de logros de gobierno) — a
  // diferencia de Actividades, esto no es un tracker de obras en curso.
  fechaInauguracion DateTime?
  inversion         Decimal?  @db.Decimal(14, 2)
  beneficiarios     String?

  provinciaId String
  provincia   Provincia @relation(fields: [provinciaId], references: [id])
  municipioId String
  municipio   Municipio @relation(fields: [municipioId], references: [id])

  publicada Boolean @default(false)

  creadoPorId String
  creadoPor   User   @relation("ObraCreador", fields: [creadoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provinciaId])
  @@index([municipioId])
  @@index([publicada])
}

// ---------------------------------------------------------------------------
// Militantes / votantes
// ---------------------------------------------------------------------------

model Militante {
  id        String  @id @default(cuid())
  nombre    String
  cedula    String  @unique
  telefono  String?
  direccion String?

  provinciaId         String
  provincia           Provincia          @relation(fields: [provinciaId], references: [id])
  municipioId         String
  municipio           Municipio          @relation(fields: [municipioId], references: [id])
  distritoMunicipalId String?
  distritoMunicipal   DistritoMunicipal? @relation(fields: [distritoMunicipalId], references: [id])
  localidadId         String?
  localidad           Localidad?         @relation(fields: [localidadId], references: [id])
  recintoElectoralId  String?
  recintoElectoral    RecintoElectoral?  @relation(fields: [recintoElectoralId], references: [id])
  colegioId           String?
  colegio             Colegio?           @relation(fields: [colegioId], references: [id])

  lat Float?
  lng Float?

  consentimientoDatos Boolean @default(false)

  // Nulo cuando el registro proviene del auto-registro público en la app (RF-26);
  // con valor cuando lo captura un promotor/digitador desde el back office (RF-11).
  capturadoPorId String?
  capturadoPor   User?   @relation("MilitanteCapturador", fields: [capturadoPorId], references: [id])
  origen         String  @default("BACKOFFICE") // BACKOFFICE | APP_PUBLICA

  // Gamificación (Fase 2)
  puntos    Int                 @default(0)
  insignias MilitanteInsignia[]

  asistencias  AsistenciaActividad[]
  deviceTokens DeviceToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provinciaId])
  @@index([municipioId])
  @@index([distritoMunicipalId])
  @@index([localidadId])
  @@index([recintoElectoralId])
  @@index([colegioId])
  @@index([cedula])
  @@index([telefono])
}

// Meta de militantes vigente por demarcación (provincia, municipio o distrito municipal).
// Editable/modificable cada cierto tiempo (RF-12): se guarda historial,
// la meta "activa" es la de vigenciaFin nula o mayor a la fecha actual.
model MetaMilitantes {
  id                  String             @id @default(cuid())
  provinciaId         String?
  provincia           Provincia?         @relation(fields: [provinciaId], references: [id])
  municipioId         String?
  municipio           Municipio?         @relation(fields: [municipioId], references: [id])
  distritoMunicipalId String?
  distritoMunicipal   DistritoMunicipal? @relation(fields: [distritoMunicipalId], references: [id])

  meta          Int
  vigenciaDesde DateTime  @default(now())
  vigenciaHasta DateTime?

  createdAt DateTime @default(now())

  @@index([provinciaId])
  @@index([municipioId])
  @@index([distritoMunicipalId])
}

// ---------------------------------------------------------------------------
// Finanzas
// ---------------------------------------------------------------------------

model Gasto {
  id             String         @id @default(cuid())
  tipo           TipoMovimiento
  monto          Decimal        @db.Decimal(14, 2)
  categoria      String
  fecha          DateTime
  comprobanteUrl String?

  secretariaId String?
  secretaria   Secretaria? @relation(fields: [secretariaId], references: [id])

  registradoPorId String
  registradoPor   User   @relation("GastoRegistrador", fields: [registradoPorId], references: [id])

  createdAt DateTime @default(now())

  @@index([secretariaId])
  @@index([fecha])
  @@index([tipo])
}

// ---------------------------------------------------------------------------
// POA (Plan Operativo Anual) por secretaría
// ---------------------------------------------------------------------------

model MetaPOA {
  id                String     @id @default(cuid())
  secretariaId      String
  secretaria        Secretaria @relation(fields: [secretariaId], references: [id])
  nombre            String
  descripcion       String?
  indicadorObjetivo Float
  fechaLimite       DateTime

  avances AvancePOA[]

  createdAt DateTime @default(now())

  @@index([secretariaId])
}

// ---------------------------------------------------------------------------
// Notificaciones push (RF-27)
// ---------------------------------------------------------------------------

model DeviceToken {
  id         String   @id @default(cuid())
  token      String   @unique
  plataforma String   @default("expo")
  // Si el dispositivo registró el token con sesión iniciada, queda ligado al
  // usuario — permite mandarle un push dirigido (p.ej. una alerta de
  // estancamiento a su responsable de zona) en vez de solo el broadcast a
  // todos los dispositivos. Nulo si se registró sin sesión (app pública).
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // La app pública no tiene cuenta de usuario, pero sí guarda localmente el id
  // del militante (carnet). Ligar el device token a ese id permite mandarle
  // push dirigido (ej. recordatorio de una actividad que confirmó) sin login.
  militanteId String?
  militante   Militante? @relation(fields: [militanteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([militanteId])
}

model Notificacion {
  id            String   @id @default(cuid())
  titulo        String
  cuerpo        String
  tipo          String // OBRA | ACTIVIDAD | CONVOCATORIA | ALERTA_META
  enviadaAt     DateTime @default(now())
  destinatarios Int      @default(0)
  // Si se llena, la notificación es dirigida a un responsable de territorio
  // específico (además de SUPERADMIN, que siempre ve todo) en vez de ser un
  // broadcast visible para todos los que antes veían el historial completo.
  destinatarioUserId String?
  destinatarioUser   User?   @relation("NotificacionDestinatario", fields: [destinatarioUserId], references: [id], onDelete: Cascade)

  @@index([destinatarioUserId])
}

// ---------------------------------------------------------------------------
// Encuestas internas (Fase 2)
// ---------------------------------------------------------------------------

model Encuesta {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  activa      Boolean  @default(true)
  creadoPorId String
  createdAt   DateTime @default(now())

  opciones EncuestaOpcion[]
  votos    EncuestaVoto[]
}

model EncuestaOpcion {
  id         String   @id @default(cuid())
  encuestaId String
  encuesta   Encuesta @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  texto      String

  votos EncuestaVoto[]

  @@index([encuestaId])
}

model EncuestaVoto {
  id            String         @id @default(cuid())
  encuestaId    String
  encuesta      Encuesta       @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  opcionId      String
  opcion        EncuestaOpcion @relation(fields: [opcionId], references: [id], onDelete: Cascade)
  cedulaVotante String
  createdAt     DateTime       @default(now())

  @@unique([encuestaId, cedulaVotante])
  @@index([opcionId])
}

// ---------------------------------------------------------------------------
// Gamificación (Fase 2)
// ---------------------------------------------------------------------------

model InsigniaDefinicion {
  id          String  @id @default(cuid())
  codigo      String  @unique
  nombre      String
  descripcion String?
  puntos      Int     @default(0)

  otorgadas MilitanteInsignia[]
}

model MilitanteInsignia {
  id          String             @id @default(cuid())
  militanteId String
  militante   Militante          @relation(fields: [militanteId], references: [id], onDelete: Cascade)
  insigniaId  String
  insignia    InsigniaDefinicion @relation(fields: [insigniaId], references: [id])
  otorgadaAt  DateTime           @default(now())

  @@unique([militanteId, insigniaId])
  @@index([militanteId])
}

model AvancePOA {
  id        String   @id @default(cuid())
  metaPoaId String
  metaPoa   MetaPOA  @relation(fields: [metaPoaId], references: [id], onDelete: Cascade)
  valor     Float
  fecha     DateTime @default(now())
  nota      String?

  registradoPorId String
  registradoPor   User   @relation("AvanceRegistrador", fields: [registradoPorId], references: [id])

  @@index([metaPoaId])
}
